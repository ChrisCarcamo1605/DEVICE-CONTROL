<nav class="top-navbar">
  <span class="navbar-page-title">
    <% if (typeof title !== 'undefined') { %><%= title %><% } %>
  </span>
  <div class="d-flex align-items-center gap-2">
    <% if (user) { %>
      <div class="navbar-user-chip">
        <div class="user-avatar">
          <%= user.full_name ? user.full_name.trim().split(/\s+/).map(n => n[0]).slice(0,2).join('').toUpperCase() : 'U' %>
        </div>
        <span><%= user.full_name %></span>
        <span class="role-pill">
          <%= user.role === 'it_manager' ? 'IT Mgr' : 'Gerente' %>
        </span>
      </div>
      <form action="/auth/logout" method="POST" class="m-0">
        <button type="submit" class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1">
          <i class="bi bi-box-arrow-right"></i>
          <span>Salir</span>
        </button>
      </form>
    <% } %>
  </div>
</nav>
