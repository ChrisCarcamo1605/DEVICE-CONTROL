<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Iniciar sesión — Device Control</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <link href="/css/theme.css" rel="stylesheet" />
  <style>
    body {
      background: linear-gradient(145deg, #09112b 0%, #0d1b35 40%, #0c2545 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
      font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    }
    .login-card {
      background: #fff;
      border-radius: 18px;
      padding: 2.5rem 2.25rem;
      width: 100%;
      max-width: 400px;
      box-shadow: 0 24px 60px rgba(0,0,0,0.35), 0 0 0 1px rgba(255,255,255,0.04);
    }
    .login-logo {
      width: 130px;
      height: auto;
      display: block;
      margin: 0 auto 1rem;
      border-radius: 10px;
    }
    .login-title {
      font-size: 1.3rem;
      font-weight: 700;
      color: #0f172a;
      letter-spacing: -0.02em;
      margin: 0 0 0.25rem;
    }
    .login-sub {
      font-size: 0.85rem;
      color: #64748b;
      margin: 0 0 2rem;
    }
    .login-btn {
      height: 42px;
      font-size: 0.925rem;
      background: #2563eb;
      border-color: #2563eb;
    }
    .login-btn:hover {
      background: #1d4ed8;
      border-color: #1d4ed8;
    }
  </style>
</head>
<body>

<div class="login-card">
  <div class="text-center">
    <img src="/img/logo.png" alt="Device Control" class="login-logo" />
    <p class="login-title">Device Control</p>
    <p class="login-sub">Asset Tracking &amp; Security</p>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger py-2 mb-3" style="font-size:0.85rem;"><%= error %></div>
  <% } %>

  <form action="/auth/login" method="POST">
    <div class="mb-3">
      <label class="form-label">Correo electrónico</label>
      <input type="email" name="email" class="form-control" required autofocus placeholder="tu@empresa.com" />
    </div>
    <div class="mb-4">
      <label class="form-label">Contraseña</label>
      <input type="password" name="password" class="form-control" required placeholder="••••••••" />
    </div>
    <button type="submit" class="btn btn-primary w-100 login-btn">
      Iniciar sesión
    </button>
  </form>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
