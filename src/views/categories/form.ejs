<div class="page-header">
  <h1><i class="bi bi-tag me-2"></i><%= title %></h1>
  <a href="/categories" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Volver
  </a>
</div>

<div class="content-card" style="max-width:400px;">
  <% if (errors.length) { %>
    <div class="alert alert-danger">
      <% errors.forEach(e => { %><div><%= e %></div><% }) %>
    </div>
  <% } %>
  <form action="<%= category ? '/categories/' + category.id : '/categories' %>" method="POST">
    <div class="mb-4">
      <label class="form-label">Nombre <span class="text-danger">*</span></label>
      <input type="text" name="name" class="form-control"
             value="<%= category?.name || '' %>" required autofocus />
    </div>
    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-primary">
        <%= category ? 'Guardar cambios' : 'Crear categoría' %>
      </button>
      <a href="/categories" class="btn btn-outline-secondary">Cancelar</a>
    </div>
  </form>
</div>
