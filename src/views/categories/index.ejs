<div class="page-header">
  <h1><i class="bi bi-tag me-2"></i>Categorías</h1>
  <a href="/categories/new" class="btn btn-primary btn-sm">
    <i class="bi bi-plus-lg me-1"></i>Nueva categoría
  </a>
</div>

<div class="content-card" style="max-width:500px;">
  <% if (categories.length === 0) { %>
    <p class="text-muted mb-0">No hay categorías registradas.</p>
  <% } else { %>
  <table class="table table-hover mb-0">
    <thead><tr><th>Nombre</th><th></th></tr></thead>
    <tbody>
      <% categories.forEach(c => { %>
      <tr>
        <td><%= c.name %></td>
        <td class="text-end">
          <a href="/categories/<%= c.id %>/edit" class="action-link">Editar</a>
          <span class="text-muted mx-1">•</span>
          <form action="/categories/<%= c.id %>/delete" method="POST" class="d-inline"
                onsubmit="return confirm('¿Eliminar esta categoría?')">
            <button type="submit" class="btn btn-link action-link p-0">Eliminar</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>
