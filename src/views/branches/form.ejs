<div class="page-header">
  <h1><i class="bi bi-building me-2"></i><%= title %></h1>
  <a href="/branches" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Volver
  </a>
</div>

<div class="content-card" style="max-width:540px;">
  <% if (errors.length) { %>
    <div class="alert alert-danger">
      <% errors.forEach(e => { %><div><%= e %></div><% }) %>
    </div>
  <% } %>

  <form action="<%= branch ? '/branches/' + branch.id : '/branches' %>" method="POST">
    <div class="mb-3">
      <label class="form-label">Nombre <span class="text-danger">*</span></label>
      <input type="text" name="name" class="form-control"
             value="<%= branch?.name || '' %>" required />
    </div>
    <div class="mb-3">
      <label class="form-label">Dirección</label>
      <input type="text" name="address" class="form-control"
             value="<%= branch?.address || '' %>" />
    </div>
    <div class="mb-3">
      <label class="form-label">Ubicación</label>
      <select name="location_id" class="form-select">
        <option value="">— Seleccionar —</option>
        <% locations.forEach(l => { %>
          <option value="<%= l.id %>" <%= branch?.location_id === l.id ? 'selected' : '' %>>
            <%= l.name %>, <%= l.department %>
          </option>
        <% }) %>
      </select>
    </div>
    <div class="mb-4">
      <label class="form-label">Teléfono</label>
      <input type="text" name="phone" class="form-control"
             value="<%= branch?.phone || '' %>" />
    </div>
    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-primary">
        <%= branch ? 'Guardar cambios' : 'Crear sucursal' %>
      </button>
      <a href="/branches" class="btn btn-outline-secondary">Cancelar</a>
    </div>
  </form>
</div>
