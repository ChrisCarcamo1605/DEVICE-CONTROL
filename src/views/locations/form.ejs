<div class="page-header">
  <h1><i class="bi bi-geo-alt me-2"></i><%= title %></h1>
  <a href="/locations" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Volver
  </a>
</div>

<div class="content-card" style="max-width:500px;">
  <% if (errors.length) { %>
    <div class="alert alert-danger">
      <% errors.forEach(e => { %><div><%= e %></div><% }) %>
    </div>
  <% } %>

  <form action="<%= location ? '/locations/' + location.id : '/locations' %>" method="POST">
    <div class="mb-3">
      <label class="form-label">Ciudad / Municipio <span class="text-danger">*</span></label>
      <input type="text" name="name" class="form-control"
             value="<%= location?.name || '' %>" required />
    </div>
    <div class="mb-3">
      <label class="form-label">Departamento <span class="text-danger">*</span></label>
      <input type="text" name="department" class="form-control"
             value="<%= location?.department || '' %>" required />
    </div>
    <div class="mb-4">
      <label class="form-label">País</label>
      <input type="text" name="country" class="form-control"
             value="<%= location?.country || 'El Salvador' %>" />
    </div>
    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-primary">
        <%= location ? 'Guardar cambios' : 'Crear ubicación' %>
      </button>
      <a href="/locations" class="btn btn-outline-secondary">Cancelar</a>
    </div>
  </form>
</div>
