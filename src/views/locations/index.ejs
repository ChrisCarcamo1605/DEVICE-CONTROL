<div class="page-header">
  <h1><i class="bi bi-geo-alt me-2"></i>Ubicaciones</h1>
  <a href="/locations/new" class="btn btn-primary btn-sm">
    <i class="bi bi-plus-lg me-1"></i>Nueva ubicación
  </a>
</div>

<div class="content-card">
  <% if (locations.length === 0) { %>
    <p class="text-muted mb-0">No hay ubicaciones registradas.</p>
  <% } else { %>
  <table class="table table-hover mb-0">
    <thead>
      <tr>
        <th>Ciudad / Municipio</th>
        <th>Departamento</th>
        <th>País</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% locations.forEach(l => { %>
      <tr>
        <td><%= l.name %></td>
        <td><%= l.department %></td>
        <td><%= l.country %></td>
        <td class="text-end">
          <a href="/locations/<%= l.id %>/edit" class="action-link">Editar</a>
          <span class="text-muted mx-1">•</span>
          <form action="/locations/<%= l.id %>/delete" method="POST" class="d-inline"
                onsubmit="return confirm('¿Eliminar esta ubicación?')">
            <button type="submit" class="btn btn-link action-link p-0">Eliminar</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>
