<div class="page-header">
  <h1><i class="bi bi-ticket-detailed me-2"></i>Nuevo ticket</h1>
  <a href="/tickets" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Volver
  </a>
</div>

<div class="content-card" style="max-width:580px;">
  <% if (errors.length) { %>
    <div class="alert alert-danger">
      <% errors.forEach(e => { %><div><%= e %></div><% }) %>
    </div>
  <% } %>

  <form action="/tickets" method="POST">
    <div class="mb-3">
      <label class="form-label">Dispositivo <span class="text-danger">*</span></label>
      <select name="device_id" class="form-select" required>
        <option value="">— Seleccionar dispositivo —</option>
        <% devices.forEach(d => { %>
          <option value="<%= d.id %>" <%= ticket?.device_id === d.id ? 'selected' : '' %>>
            <%= d.name %><%= d.serial_number ? ' — ' + d.serial_number : '' %>
            (<%= d.branch_name %>)
          </option>
        <% }) %>
      </select>
      <div class="form-text">Solo se muestran dispositivos activos.</div>
    </div>
    <div class="mb-4">
      <label class="form-label">Descripción del problema <span class="text-danger">*</span></label>
      <textarea name="problem_description" class="form-control" rows="4" required
                placeholder="Describe detalladamente el problema que presenta el equipo..."><%= ticket?.problem_description || '' %></textarea>
    </div>
    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-primary">Abrir ticket</button>
      <a href="/tickets" class="btn btn-outline-secondary">Cancelar</a>
    </div>
  </form>
</div>
