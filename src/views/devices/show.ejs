<div class="page-header">
  <div>
    <h1><i class="bi bi-cpu me-2"></i><%= device.name %></h1>
    <small class="text-muted">
      <% if (device.serial_number) { %><i class="bi bi-upc me-1"></i><%= device.serial_number %> &nbsp;•&nbsp;<% } %>
      <%= device.branch_name %>
      <% if (device.category_name) { %>&nbsp;•&nbsp; <%= device.category_name %><% } %>
    </small>
  </div>
  <div class="d-flex gap-2">
    <% if (user.role === 'it_manager') { %>
    <a href="/devices/<%= device.id %>/edit" class="btn btn-outline-secondary btn-sm">
      <i class="bi bi-pencil me-1"></i>Editar
    </a>
    <% } %>
    <a href="/devices" class="btn btn-outline-secondary btn-sm">
      <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
  </div>
</div>

<div class="row g-3 mb-3">
  <!-- Info general -->
  <div class="col-md-6">
    <div class="content-card h-100">
      <h6 class="fw-bold mb-3">Información general</h6>
      <dl class="row mb-0" style="font-size:0.875rem;">
        <dt class="col-5 text-muted">Estado</dt>
        <dd class="col-7">
          <span class="badge badge-<%= device.status %>">
            <%= { active:'Activo', in_repair:'En reparación', replaced:'Reemplazado', retired:'Retirado' }[device.status] %>
          </span>
        </dd>

        <dt class="col-5 text-muted">Sucursal</dt>
        <dd class="col-7"><%= device.branch_name %></dd>

        <dt class="col-5 text-muted">Categoría</dt>
        <dd class="col-7"><%= device.category_name || '—' %></dd>

        <dt class="col-5 text-muted">Valor</dt>
        <dd class="col-7"><%= device.value ? '$ ' + Number(device.value).toLocaleString('en-US', {minimumFractionDigits:2}) : '—' %></dd>

        <dt class="col-5 text-muted">Fecha de compra</dt>
        <dd class="col-7"><%= device.purchase_date ? new Date(device.purchase_date).toLocaleDateString('es-HN') : '—' %></dd>

        <dt class="col-5 text-muted">N° Factura</dt>
        <dd class="col-7"><%= device.invoice_number || '—' %></dd>

        <dt class="col-5 text-muted">Asignado por</dt>
        <dd class="col-7"><%= device.assigned_by_name || '—' %></dd>

        <% if (parent) { %>
        <dt class="col-5 text-muted">Parte de</dt>
        <dd class="col-7">
          <a href="/devices/<%= parent.id %>" class="action-link">
            <i class="bi bi-diagram-3 me-1"></i><%= parent.name %>
          </a>
        </dd>
        <% } %>
      </dl>
    </div>
  </div>

  <!-- Componentes -->
  <div class="col-md-6">
    <div class="content-card h-100">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-bold mb-0">Componentes (<%= components.length %>)</h6>
        <% if (user.role === 'it_manager') { %>
        <a href="/devices/new?parent_id=<%= device.id %>" class="btn btn-outline-secondary btn-sm" style="font-size:0.78rem;">
          <i class="bi bi-plus-lg"></i> Agregar
        </a>
        <% } %>
      </div>
      <% if (components.length === 0) { %>
        <p class="text-muted mb-0" style="font-size:0.875rem;">Sin componentes registrados.</p>
      <% } else { %>
        <ul class="list-unstyled mb-0">
          <% components.forEach(c => { %>
          <li class="d-flex align-items-center justify-content-between py-2 border-bottom">
            <div>
              <a href="/devices/<%= c.id %>" class="action-link fw-semibold"><%= c.name %></a>
              <% if (c.serial_number) { %>
                <small class="text-muted ms-2"><%= c.serial_number %></small>
              <% } %>
              <% if (c.category_name) { %>
                <small class="text-muted d-block"><%= c.category_name %></small>
              <% } %>
            </div>
            <span class="badge badge-<%= c.status %>" style="font-size:0.72rem;">
              <%= { active:'Activo', in_repair:'En reparación', replaced:'Reemplazado', retired:'Retirado' }[c.status] %>
            </span>
          </li>
          <% }) %>
        </ul>
      <% } %>
    </div>
  </div>
</div>

<!-- Historial de mantenimiento -->
<div class="content-card">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h6 class="fw-bold mb-0">Historial de mantenimiento</h6>
    <% if (user.role === 'it_manager') { %>
    <button class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#historyModal"
            style="font-size:0.78rem;">
      <i class="bi bi-plus-lg"></i> Agregar entrada
    </button>
    <% } %>
  </div>

  <% if (history.length === 0) { %>
    <p class="text-muted mb-0" style="font-size:0.875rem;">Sin historial de mantenimiento.</p>
  <% } else { %>
    <div class="timeline">
      <% history.forEach((h, i) => { %>
      <div class="d-flex gap-3 pb-3 <%= i < history.length - 1 ? 'border-bottom' : '' %> mb-3">
        <div class="flex-shrink-0 text-center" style="width:40px;">
          <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto"
               style="width:32px;height:32px;background:var(--bg-sidebar);">
            <i class="bi bi-<%= { diagnosis:'search', repair:'tools', replace:'arrow-repeat', new_purchase:'cart3' }[h.action] || 'clock-history' %>"
               style="font-size:0.8rem;color:var(--btn-primary);"></i>
          </div>
        </div>
        <div class="flex-grow-1">
          <div class="d-flex justify-content-between">
            <strong style="font-size:0.875rem;">
              <%= { diagnosis:'Diagnóstico', repair:'Reparación', replace:'Reemplazo', new_purchase:'Compra' }[h.action] || h.action %>
            </strong>
            <small class="text-muted"><%= new Date(h.created_at).toLocaleDateString('es-HN') %></small>
          </div>
          <div class="text-muted" style="font-size:0.8rem;">
            <i class="bi bi-person me-1"></i><%= h.manager_name %>
            <% if (h.ticket_ref) { %>
              &nbsp;•&nbsp; <a href="/tickets/<%= h.ticket_ref %>" class="action-link">Ticket</a>
            <% } %>
          </div>
          <% if (h.diagnosis) { %>
            <p class="mb-1 mt-1" style="font-size:0.875rem;"><strong>Diagnóstico:</strong> <%= h.diagnosis %></p>
          <% } %>
          <% if (h.observations) { %>
            <p class="mb-0 mt-1 text-muted" style="font-size:0.875rem;"><%= h.observations %></p>
          <% } %>
        </div>
      </div>
      <% }) %>
    </div>
  <% } %>
</div>

<!-- Modal: agregar historial -->
<% if (user.role === 'it_manager') { %>
<div class="modal fade" id="historyModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form action="/devices/<%= device.id %>/history" method="POST">
        <div class="modal-header">
          <h5 class="modal-title" style="font-size:1rem;">Agregar al historial</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Acción</label>
            <select name="action" class="form-select" required>
              <option value="diagnosis">Diagnóstico</option>
              <option value="repair">Reparación</option>
              <option value="replace">Reemplazo</option>
              <option value="new_purchase">Compra</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Diagnóstico</label>
            <input type="text" name="diagnosis" class="form-control" />
          </div>
          <div class="mb-3">
            <label class="form-label">Observaciones</label>
            <textarea name="observations" class="form-control" rows="3"></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-primary">Guardar</button>
        </div>
      </form>
    </div>
  </div>
</div>
<% } %>
