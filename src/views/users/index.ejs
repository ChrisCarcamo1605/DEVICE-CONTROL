<div class="page-header">
  <h1><i class="bi bi-people me-2"></i>Usuarios</h1>
  <a href="/users/new" class="btn btn-primary btn-sm">
    <i class="bi bi-plus-lg me-1"></i>Nuevo usuario
  </a>
</div>

<div class="content-card">
  <% if (users.length === 0) { %>
    <p class="text-muted mb-0">No hay usuarios registrados.</p>
  <% } else { %>
  <table class="table table-hover mb-0">
    <thead>
      <tr>
        <th>Nombre</th>
        <th>Correo</th>
        <th>Rol</th>
        <th>Sucursal</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(u => { %>
      <tr>
        <td class="fw-semibold"><%= u.full_name %></td>
        <td class="text-muted"><%= u.email || '—' %></td>
        <td>
          <span class="badge" style="background-color:<%= u.role === 'it_manager' ? 'var(--btn-primary)' : 'var(--btn-secondary)' %>;">
            <%= u.role === 'it_manager' ? 'IT Manager' : 'Gerente' %>
          </span>
        </td>
        <td><%= u.branch_name || '—' %></td>
        <td class="text-end">
          <a href="/users/<%= u.id %>/edit" class="action-link">Editar</a>
          <% if (u.id !== user.id) { %>
          <span class="text-muted mx-1">•</span>
          <form action="/users/<%= u.id %>/delete" method="POST" class="d-inline"
                onsubmit="return confirm('¿Eliminar este usuario?')">
            <button type="submit" class="btn btn-link action-link p-0">Eliminar</button>
          </form>
          <% } %>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>
