<div class="page-header">
  <h1><i class="bi bi-bookmark me-2"></i><%= title %></h1>
  <a href="/tags" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Volver
  </a>
</div>

<div class="content-card" style="max-width:400px;">
  <% if (errors.length) { %>
    <div class="alert alert-danger">
      <% errors.forEach(e => { %><div><%= e %></div><% }) %>
    </div>
  <% } %>
  <form action="<%= tag ? '/tags/' + tag.id : '/tags' %>" method="POST">
    <div class="mb-4">
      <label class="form-label">Nombre <span class="text-danger">*</span></label>
      <input type="text" name="name" class="form-control"
             value="<%= tag?.name || '' %>" required autofocus
             placeholder="Ej: Mojado, Roto, Falla eléctrica..." />
    </div>
    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-primary">
        <%= tag ? 'Guardar cambios' : 'Crear tag' %>
      </button>
      <a href="/tags" class="btn btn-outline-secondary">Cancelar</a>
    </div>
  </form>
</div>
